# govb-email 配置（所有配置项必填）

# 收件人，逗号分隔（必填）
EMAIL_TO=xxx@example.com

# 抄送人，逗号分隔（必填）
EMAIL_CC=xxx@example.com,yyy@example.com

# 发件人（必填）
EMAIL_FROM=xxx@example.com

# 收件人称呼（必填）
EMAIL_RECIPIENT_NAME=XXX总

# 发件人签名（必填）
EMAIL_SENDER_NAME=XXX

# 邮件主题前缀（必填）
EMAIL_SUBJECT_PREFIX=每日政采商机报告

# 邮件正文开头（必填）
EMAIL_BODY_INTRO=您好！今日采集已完成

# SMTP 服务器（必填）
EMAIL_SMTP_HOST=smtp.exmail.qq.com

# SMTP 端口（必填）
EMAIL_SMTP_PORT=465

# SMTP 用户名（必填）
EMAIL_SMTP_USER=xxx@example.com

# SMTP 密码（必填）
EMAIL_SMTP_PASSWORD=
